{% assign link_url = section.settings.link_url %}
{% assign open_new_tab = section.settings.open_new_tab %}

<style>
  #section-{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  #section-{{ section.id }} a.media-link,
  #section-{{ section.id }} div.media-link {
    display: block;
    position: relative;
    width: 100%;
  }
  #section-{{ section.id }} .media-wrap {
    width: 100%;
    display: block;
    position: relative;
  }
  #section-{{ section.id }} .media-wrap img,
  #section-{{ section.id }} .media-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  {% if section.settings.height_type_desktop == 'fullscreen' %}
  #section-{{ section.id }} .media-desktop { height: 100vh; }
  {% else %}
  #section-{{ section.id }} .media-desktop { height: {{ section.settings.height_desktop }}px; }
  {% endif %}

  {% if section.settings.height_type_mobile == 'fullscreen' %}
  #section-{{ section.id }} .media-mobile { height: 100vh; }
  {% else %}
  #section-{{ section.id }} .media-mobile { height: {{ section.settings.height_mobile }}px; }
  {% endif %}

  #section-{{ section.id }} .media-mobile { display: none; }

  #section-{{ section.id }} .media-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.text_vertical_align }};
    align-items: {{ section.settings.text_horizontal_align }};
    text-align: {{ section.settings.text_align }};
    padding: {{ section.settings.overlay_padding }}px;
    box-sizing: border-box;
    pointer-events: none;
    gap: {{ section.settings.blocks_gap }}px;
  }

  #section-{{ section.id }} .overlay-block {
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  #section-{{ section.id }} .overlay-block.type-heading {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-style: var(--font-heading-style);
    text-transform: var(--font-heading-text-transform, none);
    letter-spacing: var(--font-heading-letter-spacing, normal);
    text-shadow: 0 2px 10px rgba(0,0,0,0.35);
  }

  #section-{{ section.id }} .overlay-block.type-subheading {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-style: var(--font-heading-style);
    opacity: 0.85;
    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  #section-{{ section.id }} .overlay-block.type-text {
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-style: var(--font-body-style);
    text-shadow: 0 1px 6px rgba(0,0,0,0.25);
  }

  @media (max-width: 767px) {
    #section-{{ section.id }} .media-desktop { display: none; }
    #section-{{ section.id }} .media-mobile { display: block; }
  }
</style>

{%- liquid
  assign overlay_html = ''
  for block in section.blocks
    assign font_size_desktop = block.settings.font_size_desktop
    assign font_size_mobile = block.settings.font_size_mobile
    assign block_color = block.settings.block_color
    assign block_style = 'font-size:' | append: font_size_desktop | append: 'px;'
    if block_color != blank
      assign block_style = block_style | append: 'color:' | append: block_color | append: ';'
    endif
    assign mobile_style_tag = '<style>@media(max-width:767px){#section-' | append: section.id | append: ' [data-block="' | append: block.id | append: '"]{font-size:' | append: font_size_mobile | append: 'px!important;}}</style>'

    if block.type == 'heading'
      assign overlay_html = overlay_html | append: mobile_style_tag
      assign overlay_html = overlay_html | append: '<p class="overlay-block type-heading" data-block="' | append: block.id | append: '" style="' | append: block_style | append: '">' | append: block.settings.text | append: '</p>'
    elsif block.type == 'subheading'
      assign overlay_html = overlay_html | append: mobile_style_tag
      assign overlay_html = overlay_html | append: '<p class="overlay-block type-subheading" data-block="' | append: block.id | append: '" style="' | append: block_style | append: '">' | append: block.settings.text | append: '</p>'
    elsif block.type == 'text'
      assign overlay_html = overlay_html | append: mobile_style_tag
      assign overlay_html = overlay_html | append: '<p class="overlay-block type-text" data-block="' | append: block.id | append: '" style="' | append: block_style | append: '">' | append: block.settings.text | append: '</p>'
    endif
  endfor
-%}

<div id="section-{{ section.id }}">
  {% if link_url != blank %}
    <a class="media-link" href="{{ link_url }}"{% if open_new_tab %} target="_blank" rel="noopener"{% endif %}>
  {% else %}
    <div class="media-link">
  {% endif %}

  {%- comment -%} DESKTOP {%- endcomment -%}
  <div class="media-wrap media-desktop">
    {% if section.settings.media_type_desktop == 'image' %}
      {% if section.settings.image_desktop != blank %}
        {{ section.settings.image_desktop | image_url: width: 2000 | image_tag: loading: 'lazy', alt: section.settings.image_desktop.alt }}
      {% endif %}
    {% elsif section.settings.media_type_desktop == 'video' %}
      {% if section.settings.video_url_desktop != blank %}
        <video autoplay muted loop playsinline>
          <source src="{{ section.settings.video_url_desktop }}" type="video/mp4">
        </video>
      {% endif %}
    {% endif %}
    {% if overlay_html != blank %}
      <div class="media-overlay">{{ overlay_html }}</div>
    {% endif %}
  </div>

  {%- comment -%} MOBILE {%- endcomment -%}
  <div class="media-wrap media-mobile">
    {% if section.settings.media_type_mobile == 'image' %}
      {% if section.settings.image_mobile != blank %}
        {{ section.settings.image_mobile | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image_mobile.alt }}
      {% endif %}
    {% elsif section.settings.media_type_mobile == 'video' %}
      {% if section.settings.video_url_mobile != blank %}
        <video autoplay muted loop playsinline>
          <source src="{{ section.settings.video_url_mobile }}" type="video/mp4">
        </video>
      {% endif %}
    {% endif %}
    {% if overlay_html != blank %}
      <div class="media-overlay">{{ overlay_html }}</div>
    {% endif %}
  </div>

  {% if link_url != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Média Desktop / Mobile",
  "blocks": [
    {
      "type": "heading",
      "name": "Titre",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte du titre",
          "default": "Mon titre"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Taille (desktop, px)",
          "min": 16,
          "max": 120,
          "step": 2,
          "default": 56
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Taille (mobile, px)",
          "min": 14,
          "max": 72,
          "step": 2,
          "default": 32
        },
        {
          "type": "color",
          "id": "block_color",
          "label": "Couleur (laisse vide pour hériter)"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Sous-titre",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte du sous-titre",
          "default": "Mon sous-titre"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Taille (desktop, px)",
          "min": 12,
          "max": 72,
          "step": 2,
          "default": 28
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Taille (mobile, px)",
          "min": 12,
          "max": 48,
          "step": 2,
          "default": 20
        },
        {
          "type": "color",
          "id": "block_color",
          "label": "Couleur (laisse vide pour hériter)"
        }
      ]
    },
    {
      "type": "text",
      "name": "Texte",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Contenu",
          "default": "Mon texte descriptif"
        },
        {
          "type": "range",
          "id": "font_size_desktop",
          "label": "Taille (desktop, px)",
          "min": 12,
          "max": 48,
          "step": 1,
          "default": 18
        },
        {
          "type": "range",
          "id": "font_size_mobile",
          "label": "Taille (mobile, px)",
          "min": 12,
          "max": 36,
          "step": 1,
          "default": 15
        },
        {
          "type": "color",
          "id": "block_color",
          "label": "Couleur (laisse vide pour hériter)"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "🖥️ Desktop"
    },
    {
      "type": "select",
      "id": "media_type_desktop",
      "label": "Type de média (desktop)",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Vidéo" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image desktop"
    },
    {
      "type": "text",
      "id": "video_url_desktop",
      "label": "URL vidéo desktop (MP4)",
      "placeholder": "https://..."
    },
    {
      "type": "select",
      "id": "height_type_desktop",
      "label": "Hauteur desktop",
      "options": [
        { "value": "custom", "label": "Personnalisée (px)" },
        { "value": "fullscreen", "label": "Plein écran (100vh)" }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur desktop personnalisée (px)",
      "min": 200,
      "max": 1000,
      "step": 10,
      "default": 600
    },
    {
      "type": "header",
      "content": "📱 Mobile"
    },
    {
      "type": "select",
      "id": "media_type_mobile",
      "label": "Type de média (mobile)",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Vidéo" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile"
    },
    {
      "type": "text",
      "id": "video_url_mobile",
      "label": "URL vidéo mobile (MP4)",
      "placeholder": "https://..."
    },
    {
      "type": "select",
      "id": "height_type_mobile",
      "label": "Hauteur mobile",
      "options": [
        { "value": "custom", "label": "Personnalisée (px)" },
        { "value": "fullscreen", "label": "Plein écran (100vh)" }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Hauteur mobile personnalisée (px)",
      "min": 100,
      "max": 800,
      "step": 10,
      "default": 400
    },
    {
      "type": "header",
      "content": "✍️ Positionnement du texte"
    },
    {
      "type": "select",
      "id": "text_vertical_align",
      "label": "Position verticale",
      "options": [
        { "value": "flex-start", "label": "Haut" },
        { "value": "center", "label": "Centre" },
        { "value": "flex-end", "label": "Bas" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_horizontal_align",
      "label": "Position horizontale",
      "options": [
        { "value": "flex-start", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "flex-end", "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alignement du texte",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte (par défaut)",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "label": "Marge intérieure (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "blocks_gap",
      "label": "Espacement entre les blocs (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 12
    },
    {
      "type": "header",
      "content": "🔗 Lien"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "URL du lien (optionnel)"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Ouvrir dans un nouvel onglet",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Média Desktop / Mobile",
      "blocks": [
        { "type": "subheading" },
        { "type": "heading" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
