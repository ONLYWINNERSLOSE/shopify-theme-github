    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Couleur de fond au survol",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Couleur du texte au survol",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Couleur de bordure au survol",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
