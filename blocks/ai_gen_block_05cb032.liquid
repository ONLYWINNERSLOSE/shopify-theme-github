{% doc %}
  @prompt
    Je souhaite avoir une image avec un texte par dessus, C'est parfait, j'aimerai qu'on puisse cliquer sur l'image et que cela ramene vers un lien , C'est parfait, j'aimerai qu'on puisse cliquer sur l'image et que cela ramene vers un lien , Je souhaite également pouvoir mettre des vidéos
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-text-overlay-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-media-text-overlay__link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    text-decoration: none;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-media-text-overlay__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-media-text-overlay__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-text-overlay__video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-text-overlay__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-media-text-overlay__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-media-text-overlay__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-media-text-overlay__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    justify-content: {{ block.settings.text_vertical_alignment }};
    padding: {{ block.settings.content_padding }}px;
    text-align: {% if block.settings.text_alignment == 'flex-start' %}left{% elsif block.settings.text_alignment == 'flex-end' %}right{% else %}center{% endif %};
    pointer-events: none;
  }

  .ai-media-text-overlay__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-media-text-overlay__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    position: relative;
    z-index: 1;
  }

  .ai-media-text-overlay__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    position: relative;
    z-index: 1;
  }

  .ai-media-text-overlay__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    position: relative;
    z-index: 1;
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  .ai-media-text-overlay__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-media-text-overlay__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-media-text-overlay__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-media-text-overlay__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-media-text-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.media_link != blank %}
    <a href="{{ block.settings.media_link }}" class="ai-media-text-overlay__link-{{ ai_gen_id }}">
  {% else %}
    <div class="ai-media-text-overlay__link-{{ ai_gen_id }}">
  {% endif %}
    <div class="ai-media-text-overlay__wrapper-{{ ai_gen_id }}">
      {% if block.settings.media_type == 'video' and block.settings.video != blank %}
        {{
          block.settings.video
          | video_tag:
            image_size: '1100x',
            autoplay: block.settings.video_autoplay,
            loop: block.settings.video_loop,
            controls: block.settings.video_controls,
            muted: block.settings.video_muted,
            class: 'ai-media-text-overlay__video-' | append: ai_gen_id
        }}
      {% elsif block.settings.media_type == 'image' and block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-media-text-overlay__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-media-text-overlay__placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-media-text-overlay__empty-state-{{ ai_gen_id }}">
            Ajoutez une image ou une vidéo
          </div>
        </div>
      {% endif %}

      <div class="ai-media-text-overlay__overlay-{{ ai_gen_id }}"></div>

      <div class="ai-media-text-overlay__content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-media-text-overlay__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-media-text-overlay__text-{{ ai_gen_id }}">
            {{ block.settings.text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-media-text-overlay__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  {% if block.settings.media_link != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Image ou vidéo avec texte",
  "settings": [
    {
      "type": "header",
      "content": "Média"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Type de média",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Vidéo"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Vidéo"
    },
    {
      "type": "url",
      "id": "media_link",
      "label": "Lien du média"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur bureau",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Options vidéo"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Lecture automatique",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Lecture en boucle",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Muet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Afficher les contrôles",
      "default": false
    },
    {
      "type": "header",
      "content": "Superposition"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Couleur",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacité",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Votre titre ici"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Ajoutez votre texte descriptif ici"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Espacement intérieur",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement horizontal",
      "options": [
        {
          "value": "flex-start",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "flex-end",
          "label": "Droite"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_vertical_alignment",
      "label": "Alignement vertical",
      "options": [
        {
          "value": "flex-start",
          "label": "Haut"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "flex-end",
          "label": "Bas"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Style du texte"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
