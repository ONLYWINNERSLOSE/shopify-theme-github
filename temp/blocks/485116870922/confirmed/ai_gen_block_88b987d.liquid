{% doc %}
  @prompt
    Je souhaite avoir une image avec un texte par dessus, C'est parfait, j'aimerai qu'on puisse cliquer sur l'image et que cela ramene vers un lien , C'est parfait, j'aimerai qu'on puisse cliquer sur l'image et que cela ramene vers un lien , Je souhaite également pouvoir mettre des vidéos. Je souhaite pouvoir gérer la hauteur de la vidéo et des images. Et j'aimerai que le lien de la vidéo ne soit pas apparent
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-overlay-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-media-overlay-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-media-overlay-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    position: relative;
  }

  .ai-media-overlay-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.media_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-media-overlay-video-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.media_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-media-overlay-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.media_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-media-overlay-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-media-overlay-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-media-overlay-text-container-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 90%;
    max-width: 800px;
    z-index: 2;
    pointer-events: none;
  }

  .ai-media-overlay-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-media-overlay-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtext_size }}px;
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-media-overlay-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-media-overlay-image-{{ ai_gen_id }},
    .ai-media-overlay-video-{{ ai_gen_id }},
    .ai-media-overlay-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_media_height }}px;
    }

    .ai-media-overlay-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-media-overlay-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<media-overlay-{{ ai_gen_id }}
  class="ai-media-overlay-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-media-overlay-wrapper-{{ ai_gen_id }}">
    {% if block.settings.link_url != blank %}
      <a
        href="{{ block.settings.link_url }}"
        class="ai-media-overlay-link-{{ ai_gen_id }}"
        {% if block.settings.link_url contains 'http' %}
          target="_blank"
          rel="noopener noreferrer"
        {% endif %}
      >
    {% else %}
      <div class="ai-media-overlay-link-{{ ai_gen_id }}">
    {% endif %}

    {% if block.settings.video_url != blank %}
      <video
        class="ai-media-overlay-video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-media-overlay-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-media-overlay-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-media-overlay-empty-state-{{ ai_gen_id }}">
          Ajoutez une image ou une vidéo
        </div>
      </div>
    {% endif %}

    <div class="ai-media-overlay-overlay-{{ ai_gen_id }}"></div>

    {% if block.settings.heading != blank or block.settings.subtext != blank %}
      <div class="ai-media-overlay-text-container-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-media-overlay-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subtext != blank %}
          <p class="ai-media-overlay-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.link_url != blank %}
      </a>
    {% else %}
      </div>
    {% endif %}
  </div>
</media-overlay-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaOverlay{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.style.display = 'block';
      }

      connectedCallback() {
        const video = this.querySelector('.ai-media-overlay-video-{{ ai_gen_id }}');
        if (video) {
          video.play().catch(() => {});
        }
      }
    }

    customElements.define('media-overlay-{{ ai_gen_id }}', MediaOverlay{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image ou vidéo avec texte",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Média"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL de la vidéo",
      "info": "Collez l'URL complète de votre fichier vidéo (MP4 recommandé)"
    },
    {
      "type": "range",
      "id": "media_height",
      "label": "Hauteur sur ordinateur",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_media_height",
      "label": "Hauteur sur mobile",
      "min": 150,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Lien"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "URL du lien"
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sous-titre"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Taille du sous-titre",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Superposition"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Couleur de superposition",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacité de superposition",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Image ou vidéo avec texte"
    }
  ]
}
{% endschema %}
